generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PecaPiloto {
  id                  String   @id @default(cuid())
  referencia          String   @unique
  nome                String?
  colecao             String?
  estilista           String?
  modelista           String?
  pilotista           String?
  responsavelCorte    String?
  oficina             String?
  tamanhoPiloto       String?
  gradeCorte          String?
  fotoFrente          String?
  fotoVerso          String?
  
  // Observações Técnicas
  caracteristicasCostura String?
  pontosCriticos         String?
  maquina                String? // Manter legado
  agulha                 String? // Manter legado
  observacoesGerais      String?
  modelagens             PecaModelagem[]
  
  // Legado / Simples (Manter para compatibilidade inicial)
  fornecedor          String?
  tecido              String?
  composicao          String?
  precoTecido         Float?
  tamanhos            String?
  observacoes         String?

  // Relações para Ficha Completa
  materiais           PecaTecido[]
  aviamentos          PecaAviamento[]
  equipamentos        PecaEquipamento[]
  
  fichasCorte        PecaCorte[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PecaCorte {
  id                String   @id @default(cuid())
  pecaId            String
  peca              PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  numeroCorte       String   // Ex: 001/2026
  dataCorte         DateTime @default(now())
  observacoes       String?
  items             PecaCorteItem[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PecaCorteItem {
  id                String   @id @default(cuid())
  corteId           String
  corte             PecaCorte @relation(fields: [corteId], references: [id], onDelete: Cascade)
  
  // Dados do Tecido (reaproveitados ou manuais)
  tecidoOriginalId  String?  // Opcional: link para PecaTecido
  nome              String?
  fornecedor        String?
  cor               String?
  largura           String?
  
  // Grade de Quantidades (JSON para flexibilidade: { "M": { previsto: 10, real: 12 }, ... })
  grade             Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PecaModelagem {
  id        String   @id @default(cuid())
  pecaId    String
  peca      PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  nome      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PecaTecido {
  id            String     @id @default(cuid())
  pecaId        String
  peca          PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  referencia    String?
  descricao     String?
  nome          String?
  cor           String?
  codFornecedor String?
  composicao    String?
  largura       String?
  consumo       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model PecaAviamento {
  id            String     @id @default(cuid())
  pecaId        String
  peca          PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  referencia    String?
  descricao     String?
  nome          String?
  medida        String?
  cor           String?
  codFornecedor String?
  composicao    String?
  consumo       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model PecaEquipamento {
  id            String     @id @default(cuid())
  pecaId        String
  peca          PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  maquina       String?
  agulha        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model CorteTecido {
  id          String   @id @default(cuid())
  referencia  String   @unique
  nome        String?
  fornecedor  String?
  composicao  String?
  metragem    Float?
  largura     Float?
  preco       Float?
  cor         String?
  refCor      String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String?
  role      String   @default("user") // "admin" | "user"
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LogAlteracao {
  id           String   @id @default(cuid())
  entidade     String   // "PecaPiloto" | "CorteTecido"
  entidadeId   String
  entidadeRef  String?  // referencia da peça/tecido para exibição
  acao         String   // "criacao" | "edicao" | "exclusao" | "email_enviado"
  descricao    String?
  usuario      String
  destinatario String?  // e-mail destinatário (somente para email_enviado)
  createdAt    DateTime @default(now())
}
