generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PecaPiloto {
  id                  String   @id @default(cuid())
  referencia          String   @unique
  nome                String?
  colecao             String?
  estilista           String?
  modelista           String?
  pilotista           String?
  responsavelCorte    String?
  tamanhoPiloto       String?
  gradeCorte          String?
  fotoFrente          String?
  fotoVerso           String?
  
  // Observações Técnicas
  caracteristicasCostura String?
  pontosCriticos         String?
  maquina                String? // Manter legado
  agulha                 String? // Manter legado
  observacoesGerais      String?
  
  // Legado / Simples (Manter para compatibilidade inicial)
  fornecedor          String?
  tecido              String?
  composicao          String?
  precoTecido         Float?
  tamanhos            String?
  observacoes         String?

  // Relações para Ficha Completa
  materiais           PecaTecido[]
  aviamentos          PecaAviamento[]
  equipamentos        PecaEquipamento[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PecaTecido {
  id            String     @id @default(cuid())
  pecaId        String
  peca          PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  descricao     String?
  nome          String?
  cor           String?
  codFornecedor String?
  composicao    String?
  largura       String?
  consumo       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model PecaAviamento {
  id            String     @id @default(cuid())
  pecaId        String
  peca          PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  descricao     String?
  nome          String?
  medida        String?
  cor           String?
  codFornecedor String?
  composicao    String?
  consumo       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model PecaEquipamento {
  id            String     @id @default(cuid())
  pecaId        String
  peca          PecaPiloto @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  maquina       String?
  agulha        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model CorteTecido {
  id          String   @id @default(cuid())
  referencia  String   @unique
  nome        String?
  fornecedor  String?
  composicao  String?
  metragem    Float?
  largura     Float?
  preco       Float?
  cor         String?
  refCor      String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
